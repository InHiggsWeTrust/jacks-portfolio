---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPost = posts[0] ?? null;
---

{latestPost && (
  <section id="blog" class="section section-alt" data-testid="blog-preview-section">
    <div class="container">
      <h2 class="section-heading">Blog</h2>
      <div class="blog-preview">
        <a href={`/blog/${latestPost.id}`} class="blog-preview-card" data-testid="blog-preview-card">
          <div class="blog-thumbnail">
            {latestPost.data.heroImage ? (
              <img
                src={latestPost.data.heroImage}
                alt={latestPost.data.title}
                class="blog-img"
                loading="lazy"
              />
            ) : (
              <div class="blog-gradient gradient-accent" aria-hidden="true" />
            )}
          </div>
          <div class="blog-info">
            <time class="blog-date" datetime={latestPost.data.pubDate.toISOString()}>
              {latestPost.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <h3 class="blog-title">{latestPost.data.title}</h3>
            <p class="blog-desc">{latestPost.data.description}</p>
          </div>
        </a>
        <a href="/blog" class="btn btn-primary blog-cta" data-testid="blog-cta">Read All Posts</a>
      </div>
    </div>
  </section>
)}

<style>
  .blog-preview {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .blog-preview-card {
    display: flex;
    width: 100%;
    max-width: 680px;
    background-color: var(--bg-card);
    border: 1px solid color-mix(in srgb, var(--text-main) 8%, transparent);
    border-radius: 12px;
    overflow: hidden;
    transition: transform var(--transition), border-color var(--transition), background-color 0.3s ease;
  }

  .blog-preview-card:hover {
    transform: translateY(-4px) scale(1.05);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  }

  .blog-thumbnail {
    width: 160px;
    flex-shrink: 0;
  }

  .blog-img,
  .blog-gradient {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }



  .blog-info {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
  }

  .blog-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .blog-title {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .blog-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .blog-cta {
    font-size: 1rem;
    padding: 0.75rem 2rem;
  }

  @media (max-width: 768px) {
    .blog-preview-card {
      flex-direction: column;
    }

    .blog-thumbnail {
      width: 100%;
      aspect-ratio: 16 / 9;
    }
  }
</style>
