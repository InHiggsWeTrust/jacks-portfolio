---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="nav" data-testid="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Home" data-testid="nav-logo">
      <span class="logo-j">J</span><span class="logo-h">H</span>
    </a>
    <nav aria-label="Main navigation" data-testid="main-nav">
      <ul class="nav-links">
        <li><a href="/#experience">Experience</a></li>
        <li><a href="/#projects">Projects</a></li>
        <li><a href="/#blog">Blog</a></li>
      </ul>
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  /* ── Nav shell ───────────────────────────────────────────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background-color: color-mix(in srgb, var(--bg-primary) 80%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--text-main) 8%, transparent);
    transition: background-color 0.3s ease;
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  /* ── Logo ────────────────────────────────────────────────────── */
  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    flex-shrink: 0;
  }

  .logo-j { color: var(--text-main); }
  .logo-h { color: var(--accent); }

  /* ── Nav links ───────────────────────────────────────────────── */
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .nav-links a:hover {
    color: var(--text-main);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .nav-links {
      gap: 1.25rem;
    }
  }
</style>
