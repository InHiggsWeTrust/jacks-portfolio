---
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.png';
---

<section class="hero" data-testid="hero-section">
  <div class="container hero-inner">
    <div class="hero-content">
      <h1 class="hero-name animate-in delay-2">Jack Higglesden</h1>
      <p class="hero-title animate-in delay-4">Senior Software Engineer</p>
      <p class="hero-intro animate-in delay-5">
        Engineering Polished Interfaces with Clean Code.
      </p>
      <div class="hero-ctas animate-in delay-6">
        <a href="/#projects" class="btn btn-primary" data-testid="hero-cta-projects">View Projects</a>
      </div>
      <div class="hero-social animate-in delay-6">
        <a
          href="https://www.linkedin.com/in/jack-higglesden-b6202b170"
          target="_blank"
          rel="noopener noreferrer"
          class="hero-social-link"
          aria-label="LinkedIn profile (opens in new tab)"
          data-testid="hero-cta-linkedin"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <span class="hero-social-sep" aria-hidden="true">•</span>
        <a
          href="https://github.com/InHiggsWeTrust"
          target="_blank"
          rel="noopener noreferrer"
          class="hero-social-link"
          aria-label="GitHub profile (opens in new tab)"
          data-testid="hero-cta-github"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="hero-image-wrap animate-in delay-3" data-testid="hero-image-wrap">
      <div class="hero-image-glow" aria-hidden="true"></div>
      <Image
        src={profileImage}
        alt="A professional yet approachable headshot of Jack Higglesden in a soft-rounded circle with a subtle purple accent glow."
        class="hero-image"
        width={600}
        height={600}
        loading="eager"
        data-testid="hero-image"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 2rem 0 2rem;
  }

  .hero-inner {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .hero-content {
    flex: 1;
    max-width: 560px;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .hero-name {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: 1.125rem;
    color: var(--accent);
    font-weight: 600;
  }

  .hero-intro {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
    max-width: 480px;
    margin-inline: auto;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    margin-top: 0.75rem;
  }

  .hero-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .hero-social-link:hover {
    color: var(--accent);
  }

  .hero-social-sep {
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .hero-image-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .hero-image-glow {
    position: absolute;
    inset: -12px;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--accent) 35%, transparent),
      transparent 70%
    );
    filter: blur(24px);
    z-index: 0;
    transition: background 0.3s ease;
  }

  .hero-image {
    position: relative;
    z-index: 1;
    width: 200px;
    height: 200px;
    object-fit: cover;
    object-position: center top;
    border-radius: 50%;
    border: 6px solid var(--accent);
    display: block;
  }

  @media (max-width: 768px) {
    .hero-intro {
      max-width: 100%;
    }
  }
</style>
